# skeu environment variables

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/skeu?retryWrites=true&w=majority

# JWT
JWT_SECRET=change_me_to_a_long_random_string_minimum_32_chars

# Admin credentials
ADMIN_EMAIL=admin@skeucosmetique.com
ADMIN_PASSWORD=Admin@2024!

# Fapshi
FAPSHI_API_USER=your_fapshi_api_user
FAPSHI_API_KEY=your_fapshi_api_key
FAPSHI_BASE_URL=https://live.fapshi.com

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_WHATSAPP_NUMBER=237600000000

# Optional Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
